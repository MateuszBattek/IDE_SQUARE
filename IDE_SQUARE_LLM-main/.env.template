# Environment Variables for SQUARE IDE
# Copy this file to .env and fill in your actual values

# Ollama (local) — priority 1, free, no API key needed
# Install: https://ollama.com  |  then: ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Google Gemini — priority 2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — priority 3 (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LangSmith Configuration (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=square-ide

# Application Settings
LOG_LEVEL=INFO
DEBUG=false

# Prover Settings
Z3_TIMEOUT_MS=30000
ENABLE_EXTERNAL_PROVERS=false

# Experiment Settings
EXPERIMENT_DATA_DIR=experiments/results
REFERENCE_MODELS_DIR=experiments/reference_models
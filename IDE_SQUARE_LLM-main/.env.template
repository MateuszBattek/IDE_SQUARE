# Environment Variables for SQUARE IDE
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration (Leave empty if using Gemini)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# LangSmith Configuration (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=square-ide

# Application Settings
LOG_LEVEL=INFO
DEBUG=false

# Prover Settings
Z3_TIMEOUT_MS=30000
ENABLE_EXTERNAL_PROVERS=false

# Experiment Settings
EXPERIMENT_DATA_DIR=experiments/results
REFERENCE_MODELS_DIR=experiments/reference_models
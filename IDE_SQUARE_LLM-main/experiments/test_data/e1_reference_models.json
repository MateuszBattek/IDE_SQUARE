{
  "description": "Reference models for E1 experiment - Model Quality evaluation. Requirements contain only logical relations (A/E/I/O), system must infer state machines.",
  "version": "2.0",
  "reference_models": [
    {
      "name": "order_lifecycle",
      "description": "Order management - infer states from logical constraints",
      "requirements": "Order processing system:\n- All new orders are pending\n- All pending orders can become processing\n- All processing orders can become completed\n- No cancelled order is processing\n- No completed order is pending\n- Some orders are priority\n- Not all orders are completed",
      "expected_states": [
        {"name": "pending", "is_initial": true, "is_final": false, "properties": {}},
        {"name": "processing", "is_initial": false, "is_final": false, "properties": {}},
        {"name": "completed", "is_initial": false, "is_final": true, "properties": {}},
        {"name": "cancelled", "is_initial": false, "is_final": true, "properties": {}}
      ],
      "expected_transitions": [
        {"from_state": "pending", "to_state": "processing", "condition": "start"},
        {"from_state": "processing", "to_state": "completed", "condition": "finish"},
        {"from_state": "pending", "to_state": "cancelled", "condition": "cancel"},
        {"from_state": "processing", "to_state": "cancelled", "condition": "cancel"}
      ],
      "expected_entities": ["order", "new_order", "pending_order", "processing_order", "completed_order", "cancelled_order", "priority_order"],
      "expected_relations": [
        {"type": "universal_affirmative", "subject": "new_order", "predicate": "pending"},
        {"type": "universal_affirmative", "subject": "pending_order", "predicate": "can_become_processing"},
        {"type": "universal_affirmative", "subject": "processing_order", "predicate": "can_become_completed"},
        {"type": "universal_negative", "subject": "cancelled_order", "predicate": "processing"},
        {"type": "universal_negative", "subject": "completed_order", "predicate": "pending"},
        {"type": "particular_affirmative", "subject": "order", "predicate": "priority"},
        {"type": "particular_negative", "subject": "order", "predicate": "completed"}
      ],
      "metadata": {
        "domain": "e-commerce",
        "complexity": "medium",
        "inference_required": true
      }
    },
    {
      "name": "document_workflow",
      "description": "Document approval workflow - complex state inference",
      "requirements": "Document management workflow:\n- All new documents are in draft state\n- All draft documents require review before approval\n- No rejected document is approved\n- No approved document is in draft\n- All reviewed documents are either approved or rejected\n- Some documents require multiple reviews\n- Not all documents are approved",
      "expected_states": [
        {"name": "draft", "is_initial": true, "is_final": false, "properties": {}},
        {"name": "review", "is_initial": false, "is_final": false, "properties": {}},
        {"name": "approved", "is_initial": false, "is_final": true, "properties": {}},
        {"name": "rejected", "is_initial": false, "is_final": true, "properties": {}}
      ],
      "expected_transitions": [
        {"from_state": "draft", "to_state": "review", "condition": "submit_for_review"},
        {"from_state": "review", "to_state": "approved", "condition": "approve"},
        {"from_state": "review", "to_state": "rejected", "condition": "reject"},
        {"from_state": "rejected", "to_state": "draft", "condition": "revise"}
      ],
      "expected_entities": ["document", "new_document", "draft_document", "reviewed_document", "approved_document", "rejected_document"],
      "expected_relations": [
        {"type": "universal_affirmative", "subject": "new_document", "predicate": "draft"},
        {"type": "universal_affirmative", "subject": "draft_document", "predicate": "requires_review"},
        {"type": "universal_negative", "subject": "rejected_document", "predicate": "approved"},
        {"type": "universal_negative", "subject": "approved_document", "predicate": "draft"},
        {"type": "universal_affirmative", "subject": "reviewed_document", "predicate": "approved_or_rejected"},
        {"type": "particular_affirmative", "subject": "document", "predicate": "requires_multiple_reviews"},
        {"type": "particular_negative", "subject": "document", "predicate": "approved"}
      ],
      "metadata": {
        "domain": "enterprise",
        "complexity": "high",
        "inference_required": true
      }
    },
    {
      "name": "user_account",
      "description": "User account lifecycle - state inference from constraints",
      "requirements": "User account management:\n- All new accounts are inactive\n- All inactive accounts can be activated\n- No suspended account is active\n- No deleted account is active or suspended\n- All active accounts can be suspended\n- Some accounts are premium\n- Not all accounts are verified",
      "expected_states": [
        {"name": "inactive", "is_initial": true, "is_final": false, "properties": {}},
        {"name": "active", "is_initial": false, "is_final": false, "properties": {}},
        {"name": "suspended", "is_initial": false, "is_final": false, "properties": {}},
        {"name": "deleted", "is_initial": false, "is_final": true, "properties": {}}
      ],
      "expected_transitions": [
        {"from_state": "inactive", "to_state": "active", "condition": "activate"},
        {"from_state": "active", "to_state": "suspended", "condition": "suspend"},
        {"from_state": "suspended", "to_state": "active", "condition": "reactivate"},
        {"from_state": "active", "to_state": "deleted", "condition": "delete"},
        {"from_state": "suspended", "to_state": "deleted", "condition": "delete"}

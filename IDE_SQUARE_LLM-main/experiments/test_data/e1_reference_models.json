        {"type": "universal_negative", "subject": "resolved_ticket", "predicate": "open"},
        {"type": "universal_affirmative", "subject": "assigned_ticket", "predicate": "in_progress"},
        {"type": "particular_affirmative", "subject": "ticket", "predicate": "escalated"},
        {"type": "particular_negative", "subject": "ticket", "predicate": "resolved"}
      ],
      "metadata": {
        "domain": "customer-service",
        "complexity": "medium",
        "inference_required": true
      }
    },
    {
      "name": "payment_processing",
      "description": "Payment transaction states - complex with multiple paths",
      "requirements": "Payment processing:\n- All new payments are pending\n- All pending payments are either authorized or declined\n- No refunded payment is pending\n- No captured payment is declined\n- All authorized payments can be captured\n- All captured payments can be refunded\n- Some payments are flagged for review\n- Not all payments are captured",
      "expected_states": [
        {"name": "pending", "is_initial": true, "is_final": false, "properties": {}},
        {"name": "authorized", "is_initial": false, "is_final": false, "properties": {}},
        {"name": "declined", "is_initial": false, "is_final": true, "properties": {}},
        {"name": "captured", "is_initial": false, "is_final": false, "properties": {}},
        {"name": "refunded", "is_initial": false, "is_final": true, "properties": {}}
      ],
      "expected_transitions": [
        {"from_state": "pending", "to_state": "authorized", "condition": "authorize"},
        {"from_state": "pending", "to_state": "declined", "condition": "decline"},
        {"from_state": "authorized", "to_state": "captured", "condition": "capture"},
        {"from_state": "authorized", "to_state": "declined", "condition": "void"},
        {"from_state": "captured", "to_state": "refunded", "condition": "refund"}
      ],
      "expected_entities": ["payment", "new_payment", "pending_payment", "authorized_payment", "declined_payment", "captured_payment", "refunded_payment", "flagged_payment"],
      "expected_relations": [
        {"type": "universal_affirmative", "subject": "new_payment", "predicate": "pending"},
        {"type": "universal_affirmative", "subject": "pending_payment", "predicate": "authorized_or_declined"},
        {"type": "universal_negative", "subject": "refunded_payment", "predicate": "pending"},
        {"type": "universal_negative", "subject": "captured_payment", "predicate": "declined"},
        {"type": "universal_affirmative", "subject": "authorized_payment", "predicate": "can_be_captured"},
        {"type": "universal_affirmative", "subject": "captured_payment", "predicate": "can_be_refunded"},
        {"type": "particular_affirmative", "subject": "payment", "predicate": "flagged_for_review"},
        {"type": "particular_negative", "subject": "payment", "predicate": "captured"}
      ],
      "metadata": {
        "domain": "fintech",
        "complexity": "high",
        "inference_required": true
      }
    },
    {
      "name": "inventory_item",

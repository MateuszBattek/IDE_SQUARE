      "expected_entities": ["account", "new_account", "inactive_account", "active_account", "suspended_account", "deleted_account", "premium_account", "verified_account"],
      "expected_relations": [
        {"type": "universal_affirmative", "subject": "new_account", "predicate": "inactive"},
        {"type": "universal_affirmative", "subject": "inactive_account", "predicate": "can_be_activated"},
        {"type": "universal_negative", "subject": "suspended_account", "predicate": "active"},
        {"type": "universal_negative", "subject": "deleted_account", "predicate": "active"},
        {"type": "universal_affirmative", "subject": "active_account", "predicate": "can_be_suspended"},
        {"type": "particular_affirmative", "subject": "account", "predicate": "premium"},
        {"type": "particular_negative", "subject": "account", "predicate": "verified"}
      ],
      "metadata": {
        "domain": "identity",
        "complexity": "high",
        "inference_required": true
      }
    },
    {

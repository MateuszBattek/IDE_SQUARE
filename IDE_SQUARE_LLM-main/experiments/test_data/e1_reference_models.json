        {"name": "backordered", "is_initial": false, "is_final": false, "properties": {}}
      ],
      "expected_transitions": [
        {"from_state": "in_stock", "to_state": "reserved", "condition": "reserve"},
        {"from_state": "reserved", "to_state": "shipped", "condition": "ship"},
